<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F0"
    tools:context=".SubmitRequestActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Top Bar -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="@id/tvHeaderTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvHeaderTitle"
                app:tint="#1A1A1A" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Submit a Request"
                android:textColor="#1A1A1A"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Voice Assistant Toggle -->
            <ImageView
                android:id="@+id/ivVoiceAssistant"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_volume_up"
                app:layout_constraintBottom_toBottomOf="@id/tvHeaderTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvHeaderTitle"
                app:tint="#1A1A1A" />

            <TextView
                android:id="@+id/tvHeaderSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Submit a complaint or support request\nabout an issue with your pension application."
                android:textColor="#606060"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle" />

            <!-- Issue Selection Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/issueSelectionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#F2EFE9"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/tvHeaderSubtitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Your Issue"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Issue Options -->
                    <LinearLayout
                        android:id="@+id/optionAppStuck"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_app_stuck" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Application Stuck" android:textColor="#1A1A1A" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My application is stuck in process" android:textColor="#606060" android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView android:id="@+id/checkAppStuck" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_radio_button_checked" android:visibility="gone" app:tint="#00A651" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/optionDocRejected"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_doc_rejected" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Document Rejected" android:textColor="#1A1A1A" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="One of my documents was rejected" android:textColor="#606060" android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView android:id="@+id/checkDocRejected" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_radio_button_checked" android:visibility="gone" app:tint="#00A651" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/optionIncorrectInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_incorrect_info" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Incorrect Information" android:textColor="#1A1A1A" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My personal details are incorrect" android:textColor="#606060" android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView android:id="@+id/checkIncorrectInfo" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_radio_button_checked" android:visibility="gone" app:tint="#00A651" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/optionOtherIssue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="8dp"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_other_issue" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Other Issue" android:textColor="#1A1A1A" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="I have a different issue" android:textColor="#606060" android:textSize="12sp" />
                        </LinearLayout>
                        <ImageView android:id="@+id/checkOtherIssue" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_radio_button_checked" android:visibility="gone" app:tint="#00A651" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Describe the issue" android:textColor="#1A1A1A" android:textSize="16sp" android:textStyle="bold" />
                    <EditText android:id="@+id/etDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_description_input" android:gravity="top" android:hint="Describe the issue here..." android:textColorHint="#404040" android:minLines="3" android:padding="12dp" android:textColor="#0D0C0C" android:textSize="14sp" />

                    <LinearLayout android:id="@+id/btnAttach" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal" android:padding="4dp">
                        <TextView android:id="@+id/tvAttachmentName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Optional: Attach a photo or document" android:textColor="#606060" android:textSize="12sp" />
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_camera" app:tint="#1A1A1A" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="20dp"
                        android:text="Submit Request"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/accent_orange"
                        app:cornerRadius="18dp"
                        app:elevation="4dp"
                        app:rippleColor="#40FFFFFF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Bottom Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="28dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/white"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:src="@drawable/ic_home" app:tint="#606060" />
            <ImageView android:id="@+id/navHelp" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:src="@drawable/ic_help" app:tint="#606060" />
            <ImageView android:id="@+id/navSettings" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:src="@drawable/ic_settings" app:tint="#606060" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>