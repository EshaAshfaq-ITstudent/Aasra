<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F0"
    tools:context=".DashboardActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/loginbackground"
        android:alpha="0.15"
        android:contentDescription="@null" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="150dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <!-- Speaker Icon -->
                <ImageView
                    android:id="@+id/ivVoiceAssistant"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_volume_up"
                    android:contentDescription="Toggle Voice Assistant"
                    android:background="@drawable/bg_lang_toggle"
                    android:elevation="2dp"
                    app:tint="#1A1A1A" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfile"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/aasra"
                    android:contentDescription="Profile Picture"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="@color/white"
                    app:strokeWidth="2dp" />
            </RelativeLayout>

            <!-- Greeting -->
            <TextView
                android:id="@+id/tvHelloName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Hello, User"
                android:textColor="#1A1A1A"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="4dp"
                android:text="Welcome to Aasra,\nHow can we help you today?"
                android:textColor="#606060"
                android:textSize="17sp" />

            <!-- Action Cards -->
            <HorizontalScrollView
                android:id="@+id/hsvActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardApplyPension"
                        android:layout_width="220dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="0dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivIcon1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Apply For Pension" android:textColor="#1A1A1A" android:textSize="16sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Application" android:textColor="#606060" android:textSize="14sp" />
                            </LinearLayout>
                            <ImageView android:id="@+id/ivIcon1" android:layout_width="56dp" android:layout_height="56dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_submitted" android:contentDescription="@null" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTrackApp"
                        android:layout_width="220dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="0dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivIcon2" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Track Status" android:textColor="#1A1A1A" android:textSize="16sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View Progress" android:textColor="#606060" android:textSize="14sp" />
                            </LinearLayout>
                            <ImageView android:id="@+id/ivIcon2" android:layout_width="56dp" android:layout_height="56dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_verification" android:contentDescription="@null" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVault"
                        android:layout_width="220dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="0dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivIconVault" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Document Vault" android:textColor="#1A1A1A" android:textSize="16sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Your Saved Docs" android:textColor="#606060" android:textSize="14sp" />
                            </LinearLayout>
                            <ImageView android:id="@+id/ivIconVault" android:layout_width="56dp" android:layout_height="56dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_review" android:contentDescription="@null" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardComplaint"
                        android:layout_width="220dp"
                        android:layout_height="120dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white"
                        app:strokeWidth="0dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivIcon3" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Complaints" android:textColor="#1A1A1A" android:textSize="16sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Get Support" android:textColor="#606060" android:textSize="14sp" />
                            </LinearLayout>
                            <ImageView android:id="@+id/ivIcon3" android:layout_width="56dp" android:layout_height="56dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_phone" android:contentDescription="@null" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Recent Updates -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Recent Updates"
                android:textColor="#1A1A1A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecentUpdates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F2EFE9"
                app:strokeWidth="0dp"
                app:rippleColor="#20000000">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:id="@+id/tvUpdateTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No current application" android:textColor="#1A1A1A" android:textSize="17sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvUpdateId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Apply for pension to see status here." android:textColor="#606060" android:textSize="14sp" />
                    </LinearLayout>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_arrow_forward" android:contentDescription="View Details" app:tint="#D99B82" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Application History Section -->
            <TextView
                android:id="@+id/tvHistoryHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Application History"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvApplicationHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                tools:listitem="@layout/item_application_history"
                tools:visibility="visible" />

            <!-- FAQS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Frequently Asked Questions"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- FAQ 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/faqItem1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F2EFE9"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivExpand1" android:text="Can I check my application status?" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ivExpand1" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_add" android:contentDescription="Expand" app:tint="#1A1A1A" />
                    </RelativeLayout>
                    <TextView android:id="@+id/tvAnswer1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Yes, you can track your application in real-time using your CNIC in the 'Track Status' section." android:textColor="#606060" android:textSize="14sp" android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FAQ 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/faqItem2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F2EFE9"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivExpand2" android:text="What documents are required?" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ivExpand2" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_add" android:contentDescription="Expand" app:tint="#1A1A1A" />
                    </RelativeLayout>
                    <TextView android:id="@+id/tvAnswer2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Common documents include CNIC copy, retirement order, service book, and bank account details." android:textColor="#606060" android:textSize="14sp" android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FAQ 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/faqItem3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F2EFE9"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivExpand3" android:text="How long does the process take?" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ivExpand3" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_add" android:contentDescription="Expand" app:tint="#1A1A1A" />
                    </RelativeLayout>
                    <TextView android:id="@+id/tvAnswer3" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="The processing time typically varies from 4 to 8 weeks depending on the department and documentation." android:textColor="#606060" android:textSize="14sp" android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FAQ 4 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/faqItem4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F2EFE9"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivExpand4" android:text="Where is my document vault?" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ivExpand4" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_add" android:contentDescription="Expand" app:tint="#1A1A1A" />
                    </RelativeLayout>
                    <TextView android:id="@+id/tvAnswer4" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="You can access your Document Vault from the Dashboard to view and manage all your uploaded documents securely." android:textColor="#606060" android:textSize="14sp" android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- FAQ 5 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/faqItem5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F2EFE9"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_centerVertical="true" android:layout_toStartOf="@id/ivExpand5" android:text="How to report a problem?" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        <ImageView android:id="@+id/ivExpand5" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_add" android:contentDescription="Expand" app:tint="#1A1A1A" />
                    </RelativeLayout>
                    <TextView android:id="@+id/tvAnswer5" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Go to the Complaints section, describe your issue, and submit a ticket. Our support team will respond shortly." android:textColor="#606060" android:textSize="14sp" android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:layout_margin="20dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:src="@drawable/ic_home"
                app:tint="#D99B82"
                android:contentDescription="Home" />

            <ImageView
                android:id="@+id/navSearch"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:src="@drawable/ic_search"
                app:tint="#A0A0A0"
                android:contentDescription="Search" />



            <ImageView
                android:id="@+id/navHelp"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:src="@drawable/ic_help"
                app:tint="#A0A0A0"
                android:contentDescription="Help" />

            <ImageView
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:src="@drawable/ic_settings"
                app:tint="#A0A0A0"
                android:contentDescription="Settings" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>